{
  "manifest_version": 3,
  "name": "EyeDropper",
  "short_name": "EyeDropper",
  "version": "1.0.0",
  "description": "Escolha e salve cores usando a EyeDropper API.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "EyeDropper",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
